{
    "name": "ksfraser/exceptions",
    "description": "A comprehensive exception library for ksfraser projects with factory methods for domain-specific errors.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Kevin Fraser",
            "email": "ksfraser@example.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": ">=7.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\Exceptions\\": "src/Ksfraser/Exceptions/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Exceptions\\Tests\\": "tests/"
        }
    }
}