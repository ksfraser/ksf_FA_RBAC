{
    "name": "ksfraser/ksf-fa-rbac",
    "description": "FrontAccounting adapter for ksfraser/rbac — DB repositories, user provisioning, and FA hook integration.",
    "type": "fa-module",
    "license": "GPL-3.0",
    "require": {
        "php": ">=7.4",
        "ksfraser/rbac": "*",
        "ksfraser/exceptions": "*",
        "ksfraser/traits": "^1.2",
        "psr/log": "^1.1|^2.0|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Ksfraser\\": "src/Ksfraser/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ksfraser\\Tests\\FA\\Rbac\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "platform": {
            "php": "8.1.18"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../../../ksf_RBAC"
        },
        {
            "type": "path",
            "url": "../../../Traits"
        }
    ]
}
